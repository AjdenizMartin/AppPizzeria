# ============================================
# Pizzeria App - Production Environment
# ============================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control

# --- Database (PostgreSQL - Railway) ---
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Runtime ---
APP_ENV=production
AUTO_CREATE_TABLES=false
# PORT is injected by Railway

# --- Security ---
SECRET_KEY=generate-with-openssl-rand-base64-32
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Stripe ---
STRIPE_KEY=sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# --- Frontend ---
FRONTEND_BASE_URL=https://your-domain.com
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com
# Optional: override static frontend path served by FastAPI
# FRONTEND_DIR=/absolute/path/to/frontend-react/dist

# --- Admin ---
ADMIN_EMAILS=owner@example.com,admin@example.com

# --- Print Agent ---
PRINT_AGENT_KEY=generate-random-secret
PRINT_JOB_MAX_ATTEMPTS=3

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=app-specific-password
SMTP_FROM_EMAIL=noreply@your-domain.com
SMTP_USE_TLS=true

# --- Optional: Application ---
# LOG_LEVEL=INFO
PRINT_FAILURE_ALERT_THRESHOLD=3
ERROR_RATE_ALERT_THRESHOLD=5.0
CRITICAL_EVENTS_HISTORY_LIMIT=100
