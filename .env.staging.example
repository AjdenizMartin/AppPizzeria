# ============================================
# Pizzeria App - Staging Environment
# ============================================

DATABASE_URL=postgresql://user:password@host:5432/staging_db
APP_ENV=staging
AUTO_CREATE_TABLES=false

SECRET_KEY=generate-with-openssl-rand-base64-32
ACCESS_TOKEN_EXPIRE_MINUTES=120

STRIPE_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

FRONTEND_BASE_URL=https://staging.your-domain.com
CORS_ORIGINS=https://staging.your-domain.com

ADMIN_EMAILS=owner@example.com,qa@example.com

PRINT_AGENT_KEY=generate-random-secret-staging
PRINT_JOB_MAX_ATTEMPTS=3

SMTP_HOST=smtp.provider.com
SMTP_PORT=587
SMTP_USER=staging@your-domain.com
SMTP_PASSWORD=replace-me
SMTP_FROM_EMAIL=staging@your-domain.com
SMTP_USE_TLS=true

PRINT_FAILURE_ALERT_THRESHOLD=3
ERROR_RATE_ALERT_THRESHOLD=5.0
CRITICAL_EVENTS_HISTORY_LIMIT=100
