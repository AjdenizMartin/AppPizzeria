# Development - SQLite
DATABASE_URL=sqlite:///./pizzeria.db
APP_ENV=development
AUTO_CREATE_TABLES=true

# Production - PostgreSQL (Railway)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

STRIPE_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me_optional
SECRET_KEY=change-me-in-production
ADMIN_EMAILS=owner@example.com
FRONTEND_BASE_URL=http://127.0.0.1:5173
ACCESS_TOKEN_EXPIRE_MINUTES=120
PRINT_AGENT_KEY=shared_secret_for_printer_agent
PRINT_JOB_MAX_ATTEMPTS=3
PRINT_FAILURE_ALERT_THRESHOLD=3
ERROR_RATE_ALERT_THRESHOLD=5.0
CRITICAL_EVENTS_HISTORY_LIMIT=100
MAX_PRODUCT_IMAGE_MB=3
ALLOWED_PRODUCT_IMAGE_TYPES=image/jpeg,image/png,image/webp

# CORS - Comma-separated list of allowed origins
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
